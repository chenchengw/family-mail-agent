# Google API OAuth credentials (Desktop app client)
# Scopes: Gmail (read/send) + Calendar (create events)
# Run `npm run auth` to get GMAIL_REFRESH_TOKEN
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_USER=agentmailbox@gmail.com

# Anthropic API key
CLAUDE_API_KEY=

# Parent email addresses (recipients of the daily digest)
PARENT_A_EMAIL=
PARENT_B_EMAIL=

# Optional: Claude model override (default: claude-sonnet-4-20250514)
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Optional: set to "true" to enable dry-run mode (no emails sent, no state written)
# DRY_RUN=false
